# Browser requests should usually stay same-origin and use Next.js rewrites.
# Set BENEPICK_BACKEND_ORIGIN to your Railway backend origin.
BENEPICK_BACKEND_ORIGIN=https://your-backend.up.railway.app
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_ANALYZE_TIMEOUT_MS=65000

# Firebase Authentication (Google social login)
# Firebase Console > Project settings > Your apps > Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Social login
NEXT_PUBLIC_KAKAO_JS_KEY=
NEXT_PUBLIC_KAKAO_REDIRECT_URI=
NEXT_PUBLIC_NAVER_CLIENT_ID=
NEXT_PUBLIC_NAVER_REDIRECT_URI=
NAVER_CLIENT_SECRET=
