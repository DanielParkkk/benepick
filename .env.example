APP_ENV=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/benepick

GOV24_SERVICE_KEY=your-gov24-service-key
GOV24_BASE_URL=https://api.odcloud.kr/api/gov24/v3

BOKJIRO_SERVICE_KEY=your-bokjiro-service-key
BOKJIRO_BASE_URL=http://apis.data.go.kr/B554287/NationalWelfareInformationsV001

# ── LLM: Railway 배포 시 필수 (Ollama 미지원) ────────────
# https://console.groq.com 에서 무료 발급
GROQ_API_KEY=gsk_xxxx
GROQ_MODEL=llama-3.1-8b-instant

# LLM mode split
# - BENEPICK_LLM_MODE=experiment: use BENEPICK_EXPERIMENT_PROVIDER first
# - BENEPICK_LLM_MODE=prod: use BENEPICK_PROD_PROVIDER first
# - BENEPICK_LLM_MODE=auto: select provider from available keys
# - Local Gemma run: keep BENEPICK_LLM_PROVIDER=gemma. Railway/prod without Ollama should use BENEPICK_LLM_PROVIDER= and BENEPICK_LLM_MODE=prod.
BENEPICK_LLM_MODE=auto
BENEPICK_LLM_PROVIDER=gemma
BENEPICK_EXPERIMENT_PROVIDER=ollama
BENEPICK_PROD_PROVIDER=groq

# OpenAI settings (recommended for experiment only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama local fallback
OLLAMA_MODEL=gemma4:e4b
GEMMA_MODEL=gemma4:e4b
SUMMARY_MODEL=gemma4:e4b
TRANSLATION_MODEL=gemma4:e4b
REASONER_MODEL=gemma4:e4b

# Gemma/Gemma embedding experiment
# Use BAAI/bge-m3 for the current baseline or google/embeddinggemma-300m for the Gemma-family embedding experiment.
BENEPICK_EMBED_MODEL=BAAI/bge-m3
EMBEDDINGGEMMA_MODEL=google/embeddinggemma-300m
BENEPICK_EMBED_TRUST_REMOTE_CODE=0
# Required if the chosen embedding model is gated on Hugging Face.
HF_TOKEN=

# ── Kiwi 모델 경로 (로컬 Windows 전용, Railway 불필요) ───
# KIWI_MODEL_PATH=C:/Users/dlfns/kiwi_model

# ── RAG runtime tuning ───────────────────────────────────────
# 답변 생성 타임아웃(초): 운영 권장 15
RAG_ANSWER_TIMEOUT_SECONDS=15

# Reranker 사용 여부: Railway CPU 환경 권장 0
BENEPICK_ENABLE_RERANKER=0

# Chroma HNSW 불안정 시 numpy dense fallback 고정
BENEPICK_DISABLE_CHROMA_VECTOR=1
