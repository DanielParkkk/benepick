{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 3000
    },
    {
      "name": "Backend API (FastAPI)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "RAG API (FastAPI)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["rag.api:app", "--reload", "--host", "0.0.0.0", "--port", "8001"],
      "port": 8001
    }
  ]
}
