# BenePick Gemma4 E4B fine-tuned translation adapter
#
# Copy these values into .env when the runtime has a Linux/Colab GPU and the
# optional requirements in requirements-gemma4-lora.txt are installed.

BENEPICK_TRANSLATION_BACKEND=auto
BENEPICK_TRANSLATION_STRICT_LORA=0

GEMMA4_LORA_BASE_MODEL=unsloth/gemma-4-E4B-it-unsloth-bnb-4bit
GEMMA4_LORA_ADAPTER_PATH=models/gemma4-e4b-unsloth-lora
GEMMA4_LORA_MAX_LENGTH=1536
GEMMA4_LORA_MAX_NEW_TOKENS=192

# Existing Ollama fallback. The server will still run if the LoRA runtime is
# not available, then translation falls back to this model.
GEMMA_MODEL=gemma4:latest
TRANSLATION_MODEL=gemma4:latest
